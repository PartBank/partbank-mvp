# Copy to `.env.prod` (production) and/or `.env.lab` (lab). Both use the SAME
# variable names — each file is a self-contained config for one Supabase project.
# Scripts: `--env=lab` loads .env.lab, `--env=prod` loads .env.prod.
# The local dev server (npm run dev) reads .env.local — copy .env.lab there to dev against lab.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=   # from supabase.com/dashboard/account/tokens — needed for run-migration.mjs
NEXT_PUBLIC_APP_ENV=lab # value is lab / production. Fallback to lab if empty